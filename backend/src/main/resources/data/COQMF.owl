    <rdfs:range rdf:resource="#Objective"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#supportsProcess">
    <rdfs:domain rdf:resource="#Knowledge"/>
    <rdfs:range rdf:resource="#BusinessProcess"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#usesResource">
    <rdfs:domain rdf:resource="#BusinessProcess"/>
    <rdfs:range rdf:resource="#Resource"/>
  </owl:ObjectProperty>

