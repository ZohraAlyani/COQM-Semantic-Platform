  <!-- Object Properties -->
  <owl:ObjectProperty rdf:about="#assessesObjective">
    <rdfs:domain rdf:resource="#PerformanceIndicator"/>
    <rdfs:range rdf:resource="#Objective"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#documentedBy">
