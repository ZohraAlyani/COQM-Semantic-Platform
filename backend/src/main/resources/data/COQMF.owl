  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isObjectiveOf">
    <rdfs:domain rdf:resource="#Objective"/>
    <rdfs:range rdf:resource="#BusinessProcess"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isTemporalQualityOf">
    <rdfs:domain rdf:resource="http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl#temporal-quality"/>
    <rdfs:range rdf:resource="#BusinessProcess"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isUsedByProcess">
    <owl:inverseOf rdf:resource="#usesResource"/>
